<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= appointment ? "Edit Appointment" : "Book Your Appointment" %></title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Roboto:wght@400;700&family=Edu+AU+VIC+WA+NT+Arrows:wght@400..700&display=swap" rel="stylesheet">

  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      overflow-x: hidden;
      font-family: 'Roboto', sans-serif;
      background-color: #f4f4f4;
    }

    nav {
      background-color: #ffffff;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 40px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 25px;
      margin: 0;
      padding: 0;
    }

    nav ul li a, .login {
      text-decoration: none;
      color: #333;
      font-weight: 600;
      transition: 0.3s;
    }
    nav ul li a:hover, .login:hover {
      color: #d63384;
    }

    .form-container h1 {
      text-align: center;
      font-family: "Edu AU VIC WA NT Arrows", cursive;
      font-size: 42px;
      color: transparent;
      -webkit-text-stroke: 1.4px #d63384;
      margin-bottom: 15px;
    }

    .form-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 60px 20px;
    }

    .form-container {
      background-color: white;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
      width: 100%;
      max-width: 600px;
    }

    .form-container label {
      font-weight: 500;
      margin-bottom: 8px;
      display: block;
      color: #444;
    }

    .form-container input,
    .form-container select {
      width: 100%;
      padding: 12px;
      margin: 8px 0 18px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 15px;
    }

    .form-container button {
      width: 100%;
      padding: 12px;
      background-color: #d63384;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 18px;
      transition: 0.3s ease;
    }

    .form-container button:hover {
      background-color: #b1256b;
    }

    /* Popups — Hidden until flash message exists */
    .alert {
      display: none;
      max-width: 600px;
      margin: 15px auto;
      padding: 14px;
      border-radius: 6px;
      text-align: center;
      font-weight: 500;
      font-size: 16px;
    }

    .alert.show { display: block; }

    .alert-success { background-color: #fad6e7; color: #8a245a; }
    .alert-error { background-color: #f8d7da; color: #721c24; }

    .home-button {
      display: block;
      text-align: center;
      margin-top: 12px;
      text-decoration: none;
      color: #6C63FF;
      font-size: 16px;
    }
  </style>
</head>

<body>

<!-- 🌸 NAVBAR -->
<nav>
  <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/booknow">Book Now</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/beautyproducts">Beauty Products</a></li>
      <li><a href="/contact">Contact</a></li>
  </ul>

  <div class="nav-right">
      <% if (!user) { %>
          <a class="login" href="/login">Login</a> / 
          <a class="login" href="/signup">Sign Up</a>
      <% } else { %>
          <a class="login" href="/profile">My Profile</a> / 
          <a class="login" href="/logout">Logout</a>
      <% } %>
  </div>
</nav>


<!-- 🌸 POPUP MESSAGES -->
<% if (success_msg) { %>
  <div class="alert alert-success show"><%= success_msg %></div>
<% } %>

<% if (error_msg) { %>
  <div class="alert alert-error show"><%= error_msg %></div>
<% } %>


<!-- 🌸 FORM SECTION -->
<div class="form-wrapper">
  <div class="form-container">

    <h1><%= appointment ? "Edit Appointment" : "Book Your Appointment" %></h1>

    <form method="POST" action="/booknow">

      <input type="hidden" name="appt_id" value="<%= appointment ? appointment._id : '' %>">

      <label for="name">Full Name</label>
      <input type="text" id="name" name="name" 
             value="<%= appointment ? appointment.name : '' %>" required>

      <label for="contact">Contact Number</label>
      <input type="tel" id="contact" name="contact"
             value="<%= appointment ? appointment.contact : '' %>" required>

      <label for="gender">Gender</label>
      <select id="gender" name="gender" required>
        <option value="female" <%= appointment && appointment.gender==="female" ? "selected" : "" %>>Female</option>
        <option value="male" <%= appointment && appointment.gender==="male" ? "selected" : "" %>>Male</option>
        <option value="other" <%= appointment && appointment.gender==="other" ? "selected" : "" %>>Other</option>
      </select>

      <!-- 🌸 DATE FIELD (New Feature) -->
      <label for="date">Choose Appointment Date</label>
      <input type="date" id="date" name="date"
             min="<%= new Date().toISOString().split('T')[0] %>"
             max="<%= new Date(Date.now() + 30*24*60*60*1000).toISOString().split('T')[0] %>"
             value="<%= appointment ? appointment.date : '' %>"
             required>

      <label for="time">Preferred Time</label>
      <input type="time" id="time" name="time"
             value="<%= appointment ? appointment.time : '' %>" required>

      <label for="city">City</label>
      <input type="text" id="city" name="city"
             value="<%= appointment ? appointment.city : '' %>" required>

      <label for="state">State</label>
      <input type="text" id="state" name="state"
             value="<%= appointment ? appointment.state : '' %>" required>

      <button type="submit"><%= appointment ? "Save Changes" : "Submit Booking" %></button>
    </form>

    <a href="/" class="home-button">← Return to Home</a>
  </div>
</div>

</body>
</html>
