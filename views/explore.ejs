<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>
      <%= (category || 'Products').charAt(0).toUpperCase() + (category ||
      'products').slice(1) %> Products
    </title>
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Edu+AU+VIC+WA+NT+Arrows:wght@400..700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      body {
        background-color: #fff8f5;
        font-family: "Roboto", sans-serif;
        margin: 0;
        padding: 0;
      }
      nav {
        background: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 24px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
      }

      nav ul {
        list-style: none;
        display: flex;
        gap: 18px;
        padding: 0;
        margin: 0;
      }

      nav ul li a {
        text-decoration: none;
        color: #333;
        font-weight: 600;
      }
      h1 {
        text-align: center;
        font-family: "Edu AU VIC WA NT Arrows", cursive;
        background: linear-gradient(to right, #f3d1dc, #ffe0f0);
        padding: 30px 20px;
        -webkit-text-stroke: 1.4px #5a2a55;
        color: transparent;
        font-size: 38px;
        margin: 0;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 24px;
        padding: 36px;
        max-width: 1200px;
        margin: 0 auto 60px;
      }
      .product {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        text-align: center;
        padding: 14px;
        transition: transform 0.25s, box-shadow 0.25s;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 360px;
      }
      .product:hover {
        transform: translateY(-6px);
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
      }
      .product img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: 8px;
        flex-shrink: 0;
      }
      .price {
        font-weight: 600;
        color: #d63384;
        margin-top: 6px;
      }
      .card-footer {
        margin-top: auto;
        display: flex;
        gap: 8px;
        justify-content: center;
        align-items: center;
      }
      .add-btn,
      .view-btn {
        background-color: #d63384;
        color: white;
        border: none;
        padding: 8px 12px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
        text-decoration: none;
      }
      .view-btn {
        background: #6c63ff;
      }
      .add-btn:hover {
        background: #b1256b;
      }
      #toast {
        visibility: hidden;
        min-width: 260px;
        max-width: calc(100% - 40px);
        background: #d63384;
        color: #fff;
        text-align: center;
        border-radius: 10px;
        padding: 12px 16px;
        position: fixed;
        z-index: 1200;
        left: 50%;
        bottom: 28px;
        transform: translateX(-50%) translateY(10px);
        font-weight: 500;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        opacity: 0;
        transition: opacity 0.25s, transform 0.25s;
      }
      #toast.show {
        visibility: visible;
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      @media (max-width: 480px) {
        .grid {
          padding: 18px;
          gap: 14px;
        }
        h1 {
          font-size: 28px;
          padding: 24px;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/booknow">Book Now</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/beautyproducts">Beauty Products</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <div>
        <a
          href="/mycart"
          style="text-decoration: none; color: #333; font-weight: 600"
          >🛒 My Cart</a
        >
      </div>
    </nav>

    <h1>
      <%= (category || 'Products').charAt(0).toUpperCase() + (category ||
      'products').slice(1) %> Products
    </h1>

    <div class="grid">
      <% if (products && products.length > 0) { %> <%
      products.forEach(function(p){ const img = p.image_url &&
      p.image_url.trim() ? p.image_url : '/images/placeholder.jpg'; let rawPrice
      = p.price || ""; let numeric = String(rawPrice).replace(/[^0-9.]/g, "");
      let price = numeric ? parseFloat(numeric).toFixed(2) : "0.00"; const name
      = p.product_name || 'Unnamed product'; const type = p.product_type || '';
      const url = p.product_url || '#'; %>

      <div
        class="product"
        data-name="<%= name %>"
        data-price="<%= price %>"
        data-image="<%= img %>"
      >
        <img
          src="<%= img %>"
          alt="<%= name %>"
          onerror="this.src='/images/placeholder.jpg'"
        />
        <h3><%= name %></h3>
        <p><%= type %></p>
        <div class="price">₹ <%= price %></div>

        <div class="card-footer">
          <button class="add-btn" type="button">Add to Cart</button>
          <a class="view-btn" href="<%= url %>" target="_blank">View</a>
        </div>
      </div>

      <% }) %> <% } else { %>
      <p style="grid-column: 1/-1; text-align: center; color: #666">
        No products found for <%= category %>.
      </p>
      <% } %>
    </div>

    <div id="toast">Item added to cart</div>

    <script>
      function showToast(message) {
        const toast = document.getElementById("toast");
        toast.textContent = message;
        toast.classList.add("show");

        setTimeout(() => {
          toast.classList.remove("show");
        }, 2200);
      }

      document.querySelectorAll(".add-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          const card = this.closest(".product");

          const payload = {
            name: card.dataset.name,
            price: card.dataset.price.replace(/[^0-9.]/g, ""),
            image: card.dataset.image,
          };

          await fetch("/cart/add", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          showToast("Item added in the cart");
        });
      });
    </script>
  </body>
</html>
