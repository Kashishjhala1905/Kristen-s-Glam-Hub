<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Beauty Products | Kristen’s Glam Hub</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Roboto:wght@400;500&family=Edu+AU+VIC+WA+NT+Arrows:wght@400..700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #fff8f5;
            font-family: 'Roboto', sans-serif;
        }

        /* 🌸 NAVBAR (SAME AS SERVICES.EJS) */
        nav {
            background-color: #ffffff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 40px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 25px;
            margin: 0;
            padding: 0;
        }

        nav ul li a, .login {
            text-decoration: none;
            color: #333;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        nav ul li a:hover, .login:hover {
            color: #d63384;
        }

        /* 🌸 HEADER (EXACTLY SAME AS SERVICES.EJS) */
        header {
            text-align: center;
            padding: 40px 20px;
            background: linear-gradient(to right, #f3d1dc, #ffe0f0);
        }

        header h1 {
            font-family: "Edu AU VIC WA NT Arrows", cursive;
            font-size: 48px;
            margin: 0;
            color: #5a2a55;
        }

        /* CATEGORY */
        .category {
            margin: 50px auto;
            max-width: 1200px;
            padding: 0 20px;
        }

        .category h2 {
            color: #d63384;
            font-family: 'Playfair Display', serif;
            font-size: 2.3rem;
            text-align: center;
            margin-bottom: 20px;
            letter-spacing: 1px;
        }

        /* PRODUCT GRID */
        .product-list {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .product-card {
            background-color: white;
            width: 250px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.10);
            overflow: hidden;
            text-align: center;
            transition: all 0.3s ease;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.20);
        }

        .product-card img {
            width: 100%;
            height: 220px;
            object-fit: cover;
        }

        .product-info {
            padding: 15px;
        }

        .product-info h3 {
            font-size: 1.1rem;
            color: #333;
            margin-bottom: 8px;
        }

        .product-info p {
            font-size: 0.95rem;
            color: #777;
            margin-bottom: 10px;
        }

        .product-info button {
            background-color: #d63384;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: 0.3s;
        }

        .product-info button:hover {
            background-color: #b1256b;
        }

        /* EXPLORE BUTTON */
        .explore-btn {
            display: block;
            margin: 25px auto;
            background-color: #ffd6e8;
            color: #d63384;
            border: 2px solid #d63384;
            border-radius: 8px;
            padding: 10px 25px;
            font-weight: 600;
            text-decoration: none;
            font-size: 1rem;
            width: fit-content;
            transition: 0.3s ease;
        }

        .explore-btn:hover {
            background-color: #d63384;
            color: #fff;
            transform: scale(1.06);
        }

        /* SEPARATOR */
        .separator {
            margin: 50px auto;
            width: 80%;
            height: 2px;
            background-color: #f3b7d1;
            opacity: 0.5;
        }

        /* TOAST POPUP */
        #toast {
            visibility: hidden;
            min-width: 260px;
            max-width: calc(100% - 40px);
            background-color: #d63384;
            color: #fff;
            text-align: center;
            border-radius: 10px;
            padding: 12px 16px;
            position: fixed;
            z-index: 1200;
            left: 50%;
            bottom: 28px;
            transform: translateX(-50%) translateY(10px);
            font-weight: 500;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            opacity: 0;
            transition: opacity 0.25s ease, transform 0.25s ease;
        }
    </style>
</head>

<body>

    <!-- 🌸 NAVBAR -->
    <nav>
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/booknow">Book Now</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/beautyproducts">Beauty Products</a></li>
        <li><a href="/contact">Contact</a></li>
    </ul>

    <div class="nav-right">
        <% if (!user) { %>
            <a class="login" href="/login" class="nav-btn">Login</a> / 
            <a class="login" href="/signup" class="nav-btn">Sign Up</a>
        <% } else { %>
            <a class="login" href="/profile" class="nav-btn">My Profile</a> 
        <% } %>
    </div>
</nav>


    <!-- 🌸 HEADER (Same as Services) -->
    <header>
        <h1>Our Beauty Essentials</h1>
    </header>

    <% const sections = ["skin", "hair", "nail", "makeup"]; %>

    <% sections.forEach(section => { %>
    <section class="category">

        <h2><%= section.charAt(0).toUpperCase() + section.slice(1) %> Care</h2>

        <div class="product-list">
            <% categories[section].forEach(product => { %>

            <div class="product-card">
                <img src="<%= product.image_url %>" alt="<%= product.product_name %>"
                     onerror="this.src='/images/placeholder.jpg'">

                <div class="product-info">
                    <h3><%= product.product_name %></h3>
                    <p><%= product.price %></p>

                    <button onclick="addToCart('<%= product.product_name %>','<%= product.price %>','<%= product.image_url %>')">
                        Add to Cart
                    </button>
                </div>
            </div>

            <% }) %>
        </div>

        <a href="/explore/<%= section %>" class="explore-btn">Explore More</a>

    </section>

    <div class="separator"></div>
    <% }) %>

    <div id="toast">Added to cart!</div>

<script>
    function showToast(message) {
        const t = document.getElementById("toast");
        t.textContent = message;
        t.style.visibility = "visible";
        t.style.opacity = "1";
        t.style.transform = "translateX(-50%) translateY(0)";

        setTimeout(() => {
            t.style.opacity = "0";
            t.style.transform = "translateX(-50%) translateY(10px)";
            setTimeout(() => t.style.visibility = "hidden", 300);
        }, 2000);
    }

    function addToCart(name, price, image) {
        fetch("/cart/add", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name, price, image })
        })
        .then(res => res.json())
        .then(() => showToast(`"${name}" added to cart 💖`));
    }
</script>

</body>
</html>
