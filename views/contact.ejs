<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kristen's Glam Hub</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Roboto:wght@400;500;700&family=Edu+AU+VIC+WA+NT+Arrows:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    crossorigin="anonymous"
  />

  <style>
    body {
      font-family: 'Roboto', sans-serif;
      background: linear-gradient(135deg, #fff4f4, #ffe2f0);
      margin: 0;
      padding: 0;
      text-align: center;
      color: #333;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* 🌸 Navbar (same as services.ejs) */
    nav {
      background-color: #ffffff;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 40px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 25px;
      margin: 0;
      padding: 0;
    }

    nav ul li a, .login {
      text-decoration: none;
      color: #333;
      font-weight: 600;
      transition: color 0.3s ease;
    }

    nav ul li a:hover , .login:hover {
      color: #d63384;
    }

    main {
      flex: 1;
      padding: 20px;
    }

    h1 {
      font-family: "Edu AU VIC WA NT Arrows", cursive;
      font-size: 48px;
      margin: 30px 0 10px;
      color: #d63384;
    }

    p {
      font-size: 20px;
      margin: 10px 0;
    }

    footer {
      background-color: #fff0f5;
      padding: 20px;
      border-top: 3px solid #d63384;
      box-shadow: 0px -4px 10px rgba(0, 0, 0, 0.05);
    }

    footer a {
      color: #d63384;
      margin: 0 8px;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s ease;
    }

    footer a:hover {
      color: #a61e61;
    }

    .social-icons {
      margin: 20px 0;
      font-size: 26px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 15px;
    }

    .social-icons a {
      color: #d63384;
      transition: color 0.3s;
    }

    .social-icons a:hover {
      color: #a61e61;
    }

    .contact-punchlines {
      margin: 20px 0;
      font-style: italic;
      color: #666;
    }

    .contact-punchlines p {
      margin: 8px 0;
    }

    .home-button {
      display: inline-block;
      margin-top: 15px;
    }

    /* Responsive adjustments */
    @media screen and (max-width: 600px) {
      h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>

  <!-- 🌸 Navbar -->
  <nav>
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/booknow">Book Now</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/beautyproducts">Beauty Products</a></li>
        <li><a href="/contact">Contact</a></li>
    </ul>

    <div class="nav-right">
        <% if (!user) { %>
            <a class="login" href="/login" class="nav-btn">Login</a> / 
            <a class="login" href="/signup" class="nav-btn">Sign Up</a>
        <% } else { %>
            <a class="login" href="/profile" class="nav-btn">My Profile</a>
        <% } %>
    </div>
</nav>


  <main>
    <h1>Welcome to Kristen's Glam Hub</h1>
    <p>Your one-stop destination for all things beauty ✨</p>
  </main>

  <footer>
    <p><strong>Contact us:</strong> <a href="mailto:info@beautywebsite.com">info@beautywebsite.com</a></p>

    <div class="contact-punchlines">
      <p>💄 Let your beauty shine — we're just one message away!</p>
      <p>📞 Get glammed up. Get noticed. Get in touch!</p>
      <p>🖤 Your beauty journey starts here!</p>
    </div>

    <div class="social-icons">
      <a href="https://www.instagram.com/beautywebsite" target="_blank"><i class="fab fa-instagram"></i></a>
      <a href="https://www.facebook.com/beautywebsite" target="_blank"><i class="fab fa-facebook-f"></i></a>
      <a href="https://wa.me/+918349439349" target="_blank"><i class="fab fa-whatsapp"></i></a>
      <a href="https://www.snapchat.com/add/beautywebsite" target="_blank"><i class="fab fa-snapchat-ghost"></i></a>
      <a href="https://www.pinterest.com/beautywebsite" target="_blank"><i class="fab fa-pinterest-p"></i></a>
    </div>

    <p>© 2025 Kristen's Glam Hub. All rights reserved.</p>
  </footer>
</body>
</html>
