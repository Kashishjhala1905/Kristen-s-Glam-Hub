<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sign Up | Kristen’s Glam Hub</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&family=Edu+AU+VIC+WA+NT+Arrows:wght@400..700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            background: linear-gradient(135deg, #ffd6e8, #ffe4ef);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Roboto', sans-serif;
        }

        .box {
            width: 360px;
            background: #ffffff;
            padding: 40px;
            border-radius: 14px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.15);
            text-align: center;
        }

        h1 {
            font-family: "Edu AU VIC WA NT Arrows", cursive;
            font-size: 45px;
            margin-bottom: 10px;
            color: transparent;
            -webkit-text-stroke: 1px #d63384;
        }

        .error {
            color: red;
            margin-bottom: 12px;
            font-size: 14px;
        }

        input {
            width: 90%;
            margin: 10px 0;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 15px;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #d63384;
            color: white;
            border: none;
            font-size: 18px;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 10px;
            transition: .3s;
        }

        button:hover {
            background: #b1256b;
        }

        a {
            text-decoration: none;
            color: #d63384;
            font-weight: bold;
        }
    </style>
</head>

<body>

<div class="box">
    <h1>Sign Up</h1>

    <% if (error) { %>
        <div class="error"><%= error %></div>
    <% } %>

    <!-- 🔐 SEND OTP FIRST -->
    <form action="/signup/send-otp" method="POST">
        <input type="text" name="name" placeholder="Full Name" required>
        <input type="email" name="email" placeholder="Email Address" required>
        <input type="text" name="contact" placeholder="Contact Number" required>
        <input type="password" name="password" placeholder="Password" required>

        <button type="submit">Send OTP</button>
    </form>

    <p style="margin-top:15px;">
        Already have an account?
        <a href="/login">Login here</a>
    </p>
</div>

</body>
</html>
