<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Verify Email | Kristen’s Glam Hub</title>

    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&family=Edu+AU+VIC+WA+NT+Arrows:wght@400..700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            background: linear-gradient(135deg, #ffe4ef, #ffd6e8);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Roboto', sans-serif;
        }

        .box {
            width: 350px;
            background: #ffffff;
            padding: 35px;
            border-radius: 14px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.15);
            text-align: center;
        }

        h1 {
            font-family: "Edu AU VIC WA NT Arrows", cursive;
            font-size: 40px;
            margin-bottom: 8px;
            color: transparent;
            -webkit-text-stroke: 1px #d63384;
        }

        p {
            font-size: 14px;
            color: #555;
            margin-bottom: 15px;
        }

        .error {
            color: red;
            margin-bottom: 12px;
            font-size: 14px;
        }

        input {
            width: 90%;
            margin: 10px 0;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 15px;
            text-align: center;
            letter-spacing: 4px;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #d63384;
            color: white;
            border: none;
            font-size: 18px;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 10px;
            transition: .3s;
        }

        button:hover {
            background: #b1256b;
        }

        .resend {
            margin-top: 12px;
        }

        .resend form button {
            background: #6c63ff;
            font-size: 15px;
        }

        .resend form button:hover {
            background: #554fd8;
        }
    </style>
</head>

<body>

<div class="box">
    <h1>Verify Email</h1>
    <p>Enter the OTP sent to your email</p>

    <% if (error) { %>
        <div class="error"><%= error %></div>
    <% } %>

    <!-- VERIFY OTP -->
    <form method="POST" action="/signup/verify-otp">
        <input
            type="text"
            name="otp"
            placeholder="Enter OTP"
            maxlength="6"
            required
        >
        <button type="submit">Verify OTP</button>
    </form>

    <!-- RESEND OTP -->
    <div class="resend">
        <form method="POST" action="/signup/resend-otp">
            <button type="submit">Resend OTP</button>
        </form>
    </div>
</div>

</body>
</html>
